---
import '../styles/global.css';
import { site } from '../data/site';

interface Props {
  title: string;
  description: string;
  canonical?: string;
}

const { title, description, canonical } = Astro.props;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, site.domain).toString();
const year = new Date().getFullYear();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#bd9454" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="canonical" href={canonicalUrl} />
    <title>{title}</title>
    <meta name="description" content={description} />

    {/* Meta Pixel - PageView fires on every funnel page load */}
    <script is:inline set:html={`!function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,document,'script','https://connect.facebook.net/en_US/fbevents.js');
fbq('init', '1002211829428152');
fbq('track', 'PageView');`} />
    <noscript><img height="1" width="1" style="display:none" src="https://www.facebook.com/tr?id=1002211829428152&amp;ev=PageView&amp;noscript=1" alt="" /></noscript>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@600;700&display=swap" />

    {/* Warm the GHL connections so the iframe paints fast */}
    <link rel="preconnect" href="https://api.leadconnectorhq.com" crossorigin />
    <link rel="preconnect" href="https://link.msgsndr.com" crossorigin />
    <link rel="dns-prefetch" href="https://api.leadconnectorhq.com" />
    <link rel="dns-prefetch" href="https://link.msgsndr.com" />
    <link rel="preload" as="script" href="https://link.msgsndr.com/js/form_embed.js" />
  </head>
  <body class="min-h-screen flex flex-col bg-cream">
    {/* Top urgency banner - lowest price guaranteed claim. */}
    <div class="bg-brand-500 text-white text-center px-3 py-2 text-[11px] sm:text-xs font-bold uppercase tracking-[0.18em]">
      <span aria-hidden="true">🔒</span> Lowest Price Guaranteed · We Beat Any Written Quote
    </div>

    {/* Stripped header - centered logo, no link back, no CTA. Keeps visitors on the funnel. */}
    <header class="sticky top-0 z-40 bg-cream/95 backdrop-blur border-b border-brand-100 shadow-sm">
      <div class="container-x flex items-center justify-center py-2 lg:py-3">
        <div class="flex items-center" aria-label={site.name}>
          <img
            src="/images/brand/floors-to-you-logo.webp"
            alt="Floors To You - Where We Bring The Showroom To You"
            width="617"
            height="255"
            class="h-9 sm:h-10 lg:h-12 w-auto"
            fetchpriority="high"
            decoding="async"
          />
        </div>
      </div>
    </header>

    <main id="main" class="flex-1">
      <slot />
    </main>

    {/* Minimal footer - legal only */}
    <footer class="bg-brand-900 text-white/70 text-xs border-t border-white/10">
      <div class="container-x py-6 flex flex-col sm:flex-row items-center justify-between gap-6">
        {/* LEFT: copyright */}
        <div class="text-center sm:text-left leading-relaxed">
          © {year} {site.legalName} · All rights reserved
          <span class="mx-2 opacity-40">·</span>
          <a href="/privacy" class="text-white/80 hover:text-white">Privacy</a>
        </div>

        {/* RIGHT: Thorwell credit */}
        <div class="flex flex-col items-center sm:items-end gap-1.5 leading-none text-center sm:text-right">
          <span class="text-[10px] uppercase tracking-[0.22em] text-white/55 font-semibold">
            Site designed and hosted
          </span>
          <a
            href="https://thorwellgroup.com"
            target="_blank"
            rel="noopener"
            class="text-base sm:text-lg tracking-[0.06em] text-white font-normal hover:text-[#CBFBB4] transition-colors no-underline"
          >
            Thor<span class="text-[#CBFBB4]">w</span>ell Group Inc.
          </a>
          <a
            href="https://thorwellgroup.com"
            target="_blank"
            rel="noopener"
            class="text-[10px] tracking-[0.32em] text-white/85 hover:text-[#CBFBB4] transition-colors no-underline"
          >
            The future of flooring
          </a>
        </div>
      </div>
    </footer>

    <script>
      const reveal = new IntersectionObserver((entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-in');
            reveal.unobserve(entry.target);
          }
        }
      }, { rootMargin: '0px 0px -8% 0px', threshold: 0.08 });
      document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-zoom').forEach((el) => reveal.observe(el));

      const counter = new IntersectionObserver((entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          const el = entry.target as HTMLElement;
          const target = parseFloat(el.dataset.count || '0');
          const suffix = el.dataset.suffix || '';
          const prefix = el.dataset.prefix || '';
          const dur = 1300;
          const start = performance.now();
          const tick = (now: number) => {
            const p = Math.min(1, (now - start) / dur);
            const eased = 1 - Math.pow(1 - p, 3);
            const value = Math.round(target * eased);
            el.textContent = `${prefix}${value}${suffix}`;
            if (p < 1) requestAnimationFrame(tick);
          };
          requestAnimationFrame(tick);
          counter.unobserve(el);
        }
      }, { threshold: 0.4 });
      document.querySelectorAll('[data-count]').forEach((el) => counter.observe(el));
    </script>

    <style is:global>
      .reveal, .reveal-left, .reveal-right, .reveal-zoom { opacity: 0; transition: opacity .7s ease, transform .7s ease; }
      .reveal { transform: translateY(16px); }
      .reveal-left { transform: translateX(-24px); }
      .reveal-right { transform: translateX(24px); }
      .reveal-zoom { transform: scale(.96); }
      .is-in { opacity: 1 !important; transform: none !important; }
      .reveal-d1 { transition-delay: .08s; }
      .reveal-d2 { transition-delay: .16s; }
      .reveal-d3 { transition-delay: .24s; }
      .marquee-track { animation: marquee 28s linear infinite; }
      @keyframes marquee { from { transform: translateX(0); } to { transform: translateX(-50%); } }
    </style>
  </body>
</html>
