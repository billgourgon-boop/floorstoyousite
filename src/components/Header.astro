---
import { site } from '../data/site';
import { services } from '../data/services';
import { areas } from '../data/areas';
---
<header class="sticky top-0 z-50 bg-cream/95 backdrop-blur border-b border-brand-100">
 <div class="container-x flex items-center justify-between h-20">
 <a href="/" class="flex items-center no-underline" aria-label="Floors To You OKC - home">
 <img
 src="/images/brand/floors-to-you-logo.webp"
 alt="Floors To You - Where We Bring The Showroom To You"
 width="617"
 height="255"
 class="h-12 md:h-16 w-auto"
 loading="eager"
 fetchpriority="high"
 />
 </a>

 <nav class="hidden lg:flex items-center gap-7 text-sm font-medium" aria-label="Primary">
 <div class="relative group">
 <button class="flex items-center gap-1 text-ink hover:text-brand-700">Flooring <span aria-hidden>▾</span></button>
 <div class="absolute left-0 top-full pt-3 hidden group-hover:block">
 <ul class="card p-2 w-72">
 {services.map((s) => (
 <li><a href={`/services/${s.slug}`} class="block px-3 py-2 rounded-lg hover:bg-brand-50 no-underline text-ink">{s.shortName}</a></li>
 ))}
 <li class="border-t border-brand-100 mt-1 pt-1">
 <a href="/services" class="block px-3 py-2 rounded-lg hover:bg-brand-50 no-underline text-brand-700 font-semibold">All Flooring →</a>
 </li>
 </ul>
 </div>
 </div>

 <div class="relative group">
 <button class="flex items-center gap-1 text-ink hover:text-brand-700">Service Areas <span aria-hidden>▾</span></button>
 <div class="absolute left-0 top-full pt-3 hidden group-hover:block">
 <ul class="card p-2 w-64">
 {areas.map((a) => (
 <li><a href={`/areas/${a.slug}`} class="block px-3 py-2 rounded-lg hover:bg-brand-50 no-underline text-ink">{a.city}</a></li>
 ))}
 <li class="border-t border-brand-100 mt-1 pt-1">
 <a href="/areas" class="block px-3 py-2 rounded-lg hover:bg-brand-50 no-underline text-brand-700 font-semibold">All Areas →</a>
 </li>
 </ul>
 </div>
 </div>

 <a href="/products" class="text-ink hover:text-brand-700 no-underline">Shop</a>
 <a href="/financing" class="text-ink hover:text-brand-700 no-underline">Financing</a>
 <a href="/about" class="text-ink hover:text-brand-700 no-underline">About</a>
 </nav>

 <div class="flex items-center gap-3">
 <a href={site.emailHref} class="hidden md:inline text-brand-800 font-semibold no-underline hover:text-brand-500">
 {site.email}
 </a>
 <a href="/free-in-home-estimate" class="btn-primary text-sm py-2.5">Free Estimate</a>
 <button id="mobile-menu-btn" type="button" class="lg:hidden p-2 text-ink" aria-label="Open menu" aria-controls="mobile-menu" aria-expanded="false">
 <svg id="mobile-menu-icon-open" class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
 <path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round" />
 </svg>
 <svg id="mobile-menu-icon-close" class="h-7 w-7 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
 <path d="M6 6l12 12M18 6L6 18" stroke-linecap="round" />
 </svg>
 </button>
 </div>
 </div>

 <div id="mobile-menu" class="lg:hidden hidden bg-cream border-t border-brand-100 max-h-[calc(100vh-5rem)] overflow-y-auto">
 <nav class="container-x py-4 text-base font-medium" aria-label="Mobile primary">
 <details class="group border-b border-brand-100">
 <summary class="flex items-center justify-between py-3 cursor-pointer text-ink list-none">
 <span>Flooring</span>
 <span class="text-brand-700 transition-transform group-open:rotate-45 text-xl leading-none" aria-hidden="true">+</span>
 </summary>
 <div class="pb-3 pl-2 space-y-1">
 {services.map((s) => (
 <a href={`/services/${s.slug}`} class="block px-3 py-2 rounded-lg text-ink hover:bg-brand-50 no-underline">{s.shortName}</a>
 ))}
 <a href="/services" class="block px-3 py-2 rounded-lg text-brand-700 font-semibold hover:bg-brand-50 no-underline">All Flooring →</a>
 </div>
 </details>

 <details class="group border-b border-brand-100">
 <summary class="flex items-center justify-between py-3 cursor-pointer text-ink list-none">
 <span>Service Areas</span>
 <span class="text-brand-700 transition-transform group-open:rotate-45 text-xl leading-none" aria-hidden="true">+</span>
 </summary>
 <div class="pb-3 pl-2 space-y-1">
 {areas.map((a) => (
 <a href={`/areas/${a.slug}`} class="block px-3 py-2 rounded-lg text-ink hover:bg-brand-50 no-underline">{a.city}</a>
 ))}
 <a href="/areas" class="block px-3 py-2 rounded-lg text-brand-700 font-semibold hover:bg-brand-50 no-underline">All Areas →</a>
 </div>
 </details>

 <a href="/products" class="block py-3 border-b border-brand-100 text-ink no-underline">Shop</a>
 <a href="/financing" class="block py-3 border-b border-brand-100 text-ink no-underline">Financing</a>
 <a href="/about" class="block py-3 border-b border-brand-100 text-ink no-underline">About</a>
 <a href={site.emailHref} class="block py-3 border-b border-brand-100 text-brand-800 font-semibold no-underline">{site.email}</a>
 <a href="/free-in-home-estimate" class="btn-primary block text-center mt-4">Free Estimate</a>
 </nav>
 </div>
</header>

<script is:inline>
 (function () {
 var btn = document.getElementById('mobile-menu-btn');
 var menu = document.getElementById('mobile-menu');
 var iconOpen = document.getElementById('mobile-menu-icon-open');
 var iconClose = document.getElementById('mobile-menu-icon-close');
 if (!btn || !menu) return;

 function setOpen(open) {
 if (open) {
 menu.classList.remove('hidden');
 btn.setAttribute('aria-expanded', 'true');
 btn.setAttribute('aria-label', 'Close menu');
 if (iconOpen) iconOpen.classList.add('hidden');
 if (iconClose) iconClose.classList.remove('hidden');
 } else {
 menu.classList.add('hidden');
 btn.setAttribute('aria-expanded', 'false');
 btn.setAttribute('aria-label', 'Open menu');
 if (iconOpen) iconOpen.classList.remove('hidden');
 if (iconClose) iconClose.classList.add('hidden');
 }
 }

 btn.addEventListener('click', function () {
 setOpen(menu.classList.contains('hidden'));
 });

 menu.addEventListener('click', function (e) {
 var t = e.target;
 if (t && t.closest && t.closest('a')) {
 setOpen(false);
 }
 });

 if (window.matchMedia) {
 var mq = window.matchMedia('(min-width: 1024px)');
 var handler = function (ev) { if (ev.matches) setOpen(false); };
 if (mq.addEventListener) mq.addEventListener('change', handler);
 else if (mq.addListener) mq.addListener(handler);
 }

 document.addEventListener('keydown', function (e) {
 if ((e.key === 'Escape' || e.keyCode === 27) && !menu.classList.contains('hidden')) {
 setOpen(false);
 btn.focus();
 }
 });
 })();
</script>
