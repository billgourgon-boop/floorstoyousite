---
import FunnelLayout from '../layouts/FunnelLayout.astro';
import GoogleReviewsBadge from '../components/GoogleReviewsBadge.astro';

const title = 'Grab Your Appointment Time · Floors To You OKC';
const description = 'Pick the time that works for you. Free in-home flooring estimate across the OKC metro - lowest price guaranteed.';
---
<FunnelLayout title={title} description={description}>

  {/* ───────── HERO ───────── */}
  <section class="relative isolate overflow-hidden bg-gradient-to-br from-cream via-brand-50 to-cream">
    <div class="absolute -top-32 -right-32 -z-10 h-[36rem] w-[36rem] rounded-full bg-brand-300/30 blur-3xl" aria-hidden="true"></div>
    <div class="absolute -bottom-32 -left-32 -z-10 h-[28rem] w-[28rem] rounded-full bg-brand-500/10 blur-3xl" aria-hidden="true"></div>

    <div class="container-x pt-6 pb-12 lg:pt-12 lg:pb-16">

      {/* Centered hero copy - same voice as the survey landing page. */}
      <div class="max-w-3xl mx-auto text-center">
        <GoogleReviewsBadge class="mb-5" label="Reviewed by OKC Homeowners" />


        <p class="text-[10px] sm:text-xs uppercase tracking-[0.28em] text-brand-700 font-bold mb-3">Final Step · You're Almost Done</p>

        <h1 class="font-display font-bold leading-[1.02] tracking-tight text-4xl sm:text-5xl lg:text-6xl xl:text-7xl text-brand-800">
          Grab Your Time.
          <span class="block text-brand-500 mt-2">We'll Bring The Showroom.</span>
        </h1>

        <p class="mt-5 text-base sm:text-lg text-ink/80 leading-relaxed max-w-2xl mx-auto">
          Pick any open slot below. Your consultant will arrive on time with samples already matched to your light and trim.
        </p>
      </div>

      {/* Calendar - centered, prominent. */}
      <div id="calendar" class="mt-8 lg:mt-12 max-w-3xl mx-auto scroll-mt-20">
        <div class="rounded-xl2 bg-white ring-2 ring-brand-500 shadow-soft overflow-hidden">
          <div class="bg-gradient-to-r from-brand-700 to-brand-800 text-white px-5 py-3 sm:px-6 sm:py-4 text-center">
            <div class="text-[10px] sm:text-[11px] uppercase tracking-[0.22em] font-bold text-brand-300">Step 2 of 2 · Pick Your Time</div>
            <div class="font-display text-lg sm:text-xl font-bold mt-0.5">Schedule Your Free In-Home Estimate</div>
          </div>

          <div class="p-2 sm:p-4">
            <iframe
              src="https://api.leadconnectorhq.com/widget/booking/1z4l2qv8WsN0G63StpPC"
              style="width:100%;border:none;overflow:hidden;min-height:720px;display:block;background:#fff;"
              scrolling="no"
              id="1z4l2qv8WsN0G63StpPC"
              title="Schedule your in-home flooring estimate"
              loading="eager"
              fetchpriority="high"
            ></iframe>
          </div>
        </div>
      </div>

      {/* Horizontal value bullets - mirrors the book funnel. */}
      <ul class="mt-10 flex flex-col sm:flex-row sm:items-center sm:justify-center sm:flex-wrap gap-3 sm:gap-x-8 sm:gap-y-3 text-sm sm:text-base text-ink/85 max-w-4xl mx-auto">
        <li class="flex items-center gap-2 justify-center"><span class="text-brand-500 flex-none" aria-hidden>✓</span> Lowest price guaranteed - we beat any written quote</li>
        <li class="flex items-center gap-2 justify-center"><span class="text-brand-500 flex-none" aria-hidden>✓</span> Samples matched to your light &amp; trim</li>
        <li class="flex items-center gap-2 justify-center"><span class="text-brand-500 flex-none" aria-hidden>✓</span> 100% product &amp; labor guarantee</li>
      </ul>
    </div>
  </section>

  {/* GHL embed auto-resize */}
  <script src="https://link.msgsndr.com/js/form_embed.js" is:inline async></script>

  {/* ───────── CONFIRMATION MODAL ───────── */}
  <div
    id="fty-confirm"
    style="display:none;"
    class="fixed inset-0 z-[100] items-center justify-center bg-black/60 backdrop-blur-sm p-4"
    role="dialog"
    aria-modal="true"
    aria-labelledby="fty-confirm-title"
  >
    <div class="bg-white rounded-xl2 shadow-soft max-w-md w-full p-8 sm:p-10 text-center ring-1 ring-brand-200">
      <div class="mx-auto h-20 w-20 rounded-full bg-green-100 flex items-center justify-center">
        <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-green-600" aria-hidden="true">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
      </div>
      <h2 id="fty-confirm-title" class="mt-6 font-display text-2xl sm:text-3xl font-bold text-brand-800">
        You're booked!
      </h2>
      <p class="mt-3 text-ink/80 leading-relaxed">
        Your free in-home flooring estimate is locked in. Check your inbox for confirmation details - we'll see you soon.
      </p>
      <a
        href="/"
        class="mt-8 inline-flex items-center justify-center gap-2 rounded-xl2 bg-brand-500 text-white hover:bg-brand-600 px-7 py-3.5 font-bold text-sm shadow-soft no-underline"
      >
        Back to Website
        <svg aria-hidden="true" focusable="false" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>
  </div>

  {/* ───────── META PIXEL: Lead fires on land, Schedule fires on booking ───────── */}
  <script is:inline>
    // PageView is fired automatically by FunnelLayout. Lead fires here because the
    // visitor reached this page by submitting the intake survey on /book.
    if (typeof fbq === 'function') {
      fbq('track', 'Lead');
    }

    // Watch for booking-confirmed message from the GHL calendar widget.
    let ftyBookingHandled = false;
    window.addEventListener('message', (e) => {
      if (!e.origin || !/leadconnectorhq\.com|msgsndr\.com/.test(e.origin)) return;
      const d = e.data;
      const eventName = (d && (d.event || d.type || d.action)) || '';
      const payload = typeof d === 'string' ? d : JSON.stringify(d || {});

      // Ignore resize/scroll/height chatter from the iframe.
      if (/^(resize|height|scroll|navigate)/i.test(eventName)) return;

      const looksLikeBooking =
        /appointment.{0,30}(booked|confirmed|scheduled|created|success)/i.test(payload) ||
        /booking.{0,30}(complete|completed|confirmed|success|booked)/i.test(payload) ||
        /\b(appointmentBooked|bookingComplete(d)?|bookingConfirmed|appointment_booked|booking_success)\b/i.test(eventName);

      if (looksLikeBooking && !ftyBookingHandled) {
        ftyBookingHandled = true;
        // Push a distinct URL so Facebook attributes the Schedule+PageView pair
        // to the confirmation step, separate from the Lead landing step.
        try { history.pushState({}, '', '/book-estimate/booked'); } catch (e) {}
        if (typeof fbq === 'function') {
          fbq('track', 'PageView');
          fbq('track', 'Schedule');
        }
        const modal = document.getElementById('fty-confirm');
        if (modal) {
          modal.style.display = 'flex';
          document.body.style.overflow = 'hidden';
        }
      }
    });
  </script>
</FunnelLayout>
