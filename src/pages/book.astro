---
import FunnelLayout from '../layouts/FunnelLayout.astro';
import GoogleReviewsBadge from '../components/GoogleReviewsBadge.astro';
import { googleReviewsUrl } from '../data/testimonials';

const title = 'Save Big On New Floors · 0% APR For 24 Months · Floors To You OKC';
const description = `Qualified Oklahoma homeowners save big on new floors with 0% APR financing for 24 months. Free in-home estimate, next-day install, 100% labor guarantee across the OKC metro.`;
---
<FunnelLayout title={title} description={description}>

  {/* ───────── HERO (form embedded) ───────── */}
  <section class="relative isolate overflow-hidden bg-gradient-to-br from-cream via-brand-50 to-cream">
    <div class="absolute -top-32 -right-32 -z-10 h-[36rem] w-[36rem] rounded-full bg-brand-300/30 blur-3xl" aria-hidden="true"></div>
    <div class="absolute -bottom-32 -left-32 -z-10 h-[28rem] w-[28rem] rounded-full bg-brand-500/10 blur-3xl" aria-hidden="true"></div>

    <div class="container-x pt-4 pb-12 lg:pt-12 lg:pb-16">
      {/* TOP ROW: headline · arrow · form on desktop. Form first on mobile so it's instantly visible. */}
      <div class="grid lg:grid-cols-[1fr_auto_1fr] gap-6 lg:gap-6 items-center">

        {/* Headline */}
        <div class="order-2 lg:order-1 text-center lg:text-left">
          <GoogleReviewsBadge class="mb-5" label="Reviewed by OKC Homeowners" />


          <h1 class="font-display font-bold leading-[1.02] tracking-tight text-4xl sm:text-5xl lg:text-6xl xl:text-7xl text-brand-800">
            Lowest Price
            <span class="block text-brand-500">Guaranteed.</span>
            <span class="block mt-2">Get Your Estimate.</span>
          </h1>

          <p class="mt-5 text-base sm:text-lg text-ink/80 leading-relaxed max-w-xl mx-auto lg:mx-0">
            <strong class="text-brand-800">0% APR for 24 months · Installed in as little as 24 hours.</strong> Free in-home measure across the entire OKC metro.
          </p>

          <p class="mt-6 font-display font-semibold text-brand-700 text-sm sm:text-base">
            Oklahoma's Largest In-Stock Flooring Showroom
          </p>
        </div>

        {/* Pulsing arrow - sits between headline and form on desktop only. */}
        <div class="hidden lg:flex order-2 items-center justify-center px-2" aria-hidden="true">
          <div class="fty-arrow-pulse text-brand-500">
            <svg width="72" height="36" viewBox="0 0 72 36" fill="none" stroke="currentColor" stroke-width="5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 18 L60 18" />
              <polyline points="46 6 60 18 46 30" />
            </svg>
          </div>
        </div>

        {/* Form card - shows first on mobile so it's instantly visible above the fold. */}
        <div id="form" class="order-1 lg:order-3 scroll-mt-20">
          <div class="rounded-xl2 bg-white ring-2 ring-brand-500 shadow-soft overflow-hidden">
            <div class="bg-gradient-to-r from-brand-700 to-brand-800 text-white px-5 py-3 sm:px-6 sm:py-4">
              <div class="text-[10px] sm:text-[11px] uppercase tracking-[0.22em] font-bold text-brand-300">Free · No obligation · 60 seconds</div>
              <div class="font-display text-lg sm:text-xl font-bold mt-0.5">Get Your Estimate</div>
            </div>

            <iframe
              src="https://api.leadconnectorhq.com/widget/survey/jWARw7xCkBcUAI4uUldA"
              scrolling="no"
              id="jWARw7xCkBcUAI4uUldA"
              title="Book a free in-home flooring estimate"
              loading="eager"
              fetchpriority="high"
              style="border:0;width:100%;height:580px;display:block;background:#fff;"
            ></iframe>
          </div>
          <p class="mt-3 text-center text-[11px] sm:text-xs text-ink/55 leading-relaxed">
            By submitting, you agree to be contacted by Floors To You OKC. We never share your info.
          </p>
        </div>

      </div>

      {/* BOTTOM ROW: 3 value bullets, horizontal on desktop, stacked on mobile. */}
      <ul class="mt-10 flex flex-col sm:flex-row sm:items-center sm:justify-center sm:flex-wrap gap-3 sm:gap-x-8 sm:gap-y-3 text-sm sm:text-base text-ink/85 max-w-4xl mx-auto">
        <li class="flex items-center gap-2 justify-center"><span class="text-brand-500 flex-none" aria-hidden>✓</span> Lowest price guaranteed - we'll beat any written quote</li>
        <li class="flex items-center gap-2 justify-center"><span class="text-brand-500 flex-none" aria-hidden>✓</span> Next-day install on in-stock material</li>
        <li class="flex items-center gap-2 justify-center"><span class="text-brand-500 flex-none" aria-hidden>✓</span> 100% product &amp; labor guarantee</li>
      </ul>
    </div>

    {/* Form embed script + post-submit redirect. */}
    <script src="https://link.msgsndr.com/js/form_embed.js" is:inline async></script>
    <script is:inline>
      const FTY_BOOK_REDIRECT = '/book-estimate';
      let ftyRedirected = false;
      window.addEventListener('message', (e) => {
        if (!e.origin || !/leadconnectorhq\.com|msgsndr\.com/.test(e.origin)) return;
        const d = e.data;
        const submitted =
          (typeof d === 'string' && /submit/i.test(d)) ||
          (d && (d.type === 'form_submit_redirect' || d.type === 'survey_submit_redirect' || d.type === 'form_submit_action' || /submit/i.test(d.event || d.type || '')));
        if (submitted && !ftyRedirected) {
          ftyRedirected = true;
          window.top.location.href = FTY_BOOK_REDIRECT;
        }
      });
    </script>
  </section>

  {/* ───────── REVIEWS ───────── */}
  <section class="bg-white py-14 lg:py-20">
    <div class="container-x">
      <div class="text-center max-w-2xl mx-auto">
        <p class="eyebrow mb-3 text-brand-500">What OKC Homeowners Say</p>
        <h2 class="font-display text-2xl sm:text-3xl lg:text-4xl font-bold text-brand-800 leading-tight">
          "I Can't Believe These Are My Floors."
        </h2>
        <p class="mt-3 text-ink/70 text-sm sm:text-base">The reaction we hear most often when homeowners walk in after we leave. Read it for yourself on Google.</p>

        <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center items-center">
          <GoogleReviewsBadge label="Our Google Reviews" />
          <a href={googleReviewsUrl} target="_blank" rel="noopener" class="btn-primary">
            <span aria-hidden>★</span> Read Our Reviews On Google
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* ───────── MID-PAGE OFFER ───────── */}
  <section class="relative isolate overflow-hidden text-white">
    <div class="absolute inset-0 -z-10 bg-gradient-to-r from-brand-900 via-brand-800 to-brand-700"></div>
    <div class="absolute left-0 top-0 bottom-0 w-1.5 bg-brand-500 -z-10"></div>

    <div class="container-x py-14 lg:py-20 text-center max-w-3xl mx-auto">
      <p class="text-[11px] sm:text-xs uppercase tracking-[0.28em] text-brand-300 font-bold mb-4">Stay On The Couch · We Bring It All</p>
      <h2 class="text-white font-display text-3xl sm:text-4xl lg:text-5xl font-bold leading-tight">
        Lowest Price Guaranteed.
        <span class="block text-brand-400 mt-2">0% APR For 24 Months.</span>
      </h2>
      <p class="mt-5 text-white/85 text-base sm:text-lg max-w-xl mx-auto">
        We bring the samples. We measure. We install. You pick the floor you love and wait for the wow.
      </p>
      <a
        href="#form"
        class="mt-8 inline-flex items-center justify-center gap-2 rounded-xl2 bg-brand-500 hover:bg-brand-600 text-white text-base sm:text-lg font-bold uppercase tracking-wider px-8 sm:px-10 py-4 sm:py-5 shadow-soft no-underline"
      >
        See If You Qualify
        <svg aria-hidden="true" focusable="false" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>
  </section>

  {/* ───────── SERVICE AREA & CREDIBILITY ───────── */}
  <section class="bg-cream py-14 lg:py-20">
    <div class="container-x">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center max-w-6xl mx-auto">
        <div>
          <p class="eyebrow mb-3 text-brand-500">We Come To You</p>
          <h2 class="font-display text-2xl sm:text-3xl lg:text-4xl font-bold text-brand-800 leading-tight mb-5">
            Anywhere In The OKC Metro - On Your Schedule.
          </h2>
          <p class="text-ink/80 text-base sm:text-lg leading-relaxed mb-5">
            Oklahoma City · Edmond · Yukon · Mustang · Midwest City · Moore · Norman · Guthrie - we load the truck and meet you in your living room.
          </p>
          <ul class="space-y-3 text-ink/85">
            <li class="flex items-start gap-3">
              <span class="text-brand-500 mt-0.5 flex-none" aria-hidden>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              <span><strong class="text-brand-800">Licensed, Insured &amp; Locally Owned</strong> since 2018</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-brand-500 mt-0.5 flex-none" aria-hidden>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              <span><strong class="text-brand-800">Beautiful new floors installed in as little as 24 hours</strong> on in-stock material</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-brand-500 mt-0.5 flex-none" aria-hidden>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              <span><strong class="text-brand-800">100% product &amp; labor guarantee</strong> - no fine print</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-brand-500 mt-0.5 flex-none" aria-hidden>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              <span><strong class="text-brand-800">0% APR financing for 24 months</strong> with quick online approval</span>
            </li>
          </ul>
        </div>

        <div class="rounded-xl2 overflow-hidden shadow-soft ring-1 ring-brand-200">
          <img
            src="/images/photos/install/flooringinstallation.webp"
            alt="Floors To You OKC installer fitting new flooring in an Oklahoma City home"
            width="800"
            height="600"
            loading="lazy"
            class="w-full h-auto object-cover aspect-[4/3]"
          />
        </div>
      </div>
    </div>
  </section>

  {/* ───────── FINAL URGENCY ───────── */}
  <section class="relative isolate overflow-hidden text-white">
    <div class="absolute inset-0 -z-10 bg-brand-900"></div>
    <div class="absolute -top-32 -right-32 -z-10 h-[28rem] w-[28rem] rounded-full bg-brand-500/25 blur-3xl"></div>
    <div class="absolute -bottom-32 -left-32 -z-10 h-[24rem] w-[24rem] rounded-full bg-brand-500/15 blur-3xl"></div>

    <div class="container-x py-14 lg:py-20 text-center max-w-3xl mx-auto">
      <p class="text-[11px] sm:text-xs uppercase tracking-[0.28em] text-brand-300 font-bold mb-4">A Few Estimate Spots Still Available</p>
      <h2 class="text-white font-display text-3xl sm:text-4xl lg:text-5xl font-bold leading-tight">
        Your Couch. Your Showroom.
        <span class="block text-brand-400 mt-2">Your New Favorite Floor.</span>
      </h2>
      <p class="mt-5 text-white/85 text-base sm:text-lg max-w-xl mx-auto">
        Book in 60 seconds. We bring everything. You pick the one you love. The "wow" takes care of itself.
      </p>

      <a
        href="#form"
        class="mt-8 inline-flex items-center justify-center gap-2 rounded-xl2 bg-brand-500 hover:bg-brand-600 text-white text-base sm:text-lg font-bold uppercase tracking-wider px-8 sm:px-10 py-4 sm:py-5 shadow-soft no-underline"
      >
        See If You Qualify
        <svg aria-hidden="true" focusable="false" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>

      <div class="mt-10 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-[11px] uppercase tracking-[0.22em] text-white/60 font-semibold">
        <span>Locally Owned</span>
        <span class="opacity-30">·</span>
        <span>100% Guarantee</span>
        <span class="opacity-30">·</span>
        <span>Next-Day Install</span>
        <span class="opacity-30">·</span>
        <span>0% APR · 24mo</span>
      </div>
    </div>
  </section>

  <style>
    @keyframes fty-arrow-shoot {
      0%   { transform: translateX(-12px) scale(1);   opacity: 0.55; }
      50%  { transform: translateX(8px)   scale(1.08); opacity: 1; }
      100% { transform: translateX(-12px) scale(1);   opacity: 0.55; }
    }
    .fty-arrow-pulse {
      animation: fty-arrow-shoot 1.2s ease-in-out infinite;
      filter: drop-shadow(0 4px 12px rgba(189, 148, 84, 0.4));
    }
    @media (prefers-reduced-motion: reduce) {
      .fty-arrow-pulse { animation: none; }
    }
  </style>
</FunnelLayout>
