---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import CtaBand from '../components/CtaBand.astro';
import WhyUs from '../components/WhyUs.astro';
import BreadcrumbSchema from '../components/schema/BreadcrumbSchema.astro';
---
<BaseLayout
 title="Free In-Home Flooring Estimate | Oklahoma City | Floors To You OKC"
 description="Book a free in-home flooring estimate in Oklahoma City, Edmond, Yukon, Mustang, Moore, Norman or Guthrie. Written quote within one business day."
>
 <Breadcrumb items={[{ name: 'Home', url: '/' }, { name: 'Free In-Home Estimate', url: '/free-in-home-estimate' }]} />

 <section class="container-x py-12">
 <p class="eyebrow mb-3">Free Service</p>
 <h1 class="mb-4">No Showroom Hopping. We Come To You.</h1>
 <p class="text-lg text-ink/80 max-w-2xl mb-8">Skip the drive across OKC. A Floors To You consultant brings the samples to your home, matches them to your actual light and trim, measures the space, and leaves you with a written, same-day quote - zero pressure.</p>
 <img src="/images/photos/install/measuringflooring.webp" alt="Floors To You OKC consultant measuring a room during a free in-home estimate" width="1600" height="700" loading="lazy" class="w-full h-auto rounded-xl2 shadow-soft aspect-[21/9] object-cover" />
 </section>

 <WhyUs />
 <CtaBand />

 <Fragment slot="head">
 <BreadcrumbSchema items={[{ name: 'Home', url: '/' }, { name: 'Free In-Home Estimate', url: '/free-in-home-estimate' }]} />
 </Fragment>
</BaseLayout>
