---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import AreaGrid from '../components/AreaGrid.astro';
import Testimonials from '../components/Testimonials.astro';
import GoogleReviewsBadge from '../components/GoogleReviewsBadge.astro';
import { googleReviewsUrl } from '../data/testimonials';
import WhyUs from '../components/WhyUs.astro';
import CtaBand from '../components/CtaBand.astro';
import FAQ from '../components/FAQ.astro';
import Gallery from '../components/Gallery.astro';
import FAQSchema from '../components/schema/FAQSchema.astro';
import { generalFaqs } from '../data/faqs';

const galleryItems = [
 { src: '/images/photos/hardwood/hardwoodinsun1.webp', alt: 'Sun-lit Oklahoma City living room with wide-plank engineered wood flooring' },
 { src: '/images/photos/lvp/vinyl.webp', alt: 'Waterproof vinyl flooring in a sun-lit OKC home' },
 { src: '/images/photos/laminate/lamiantekitchen.webp', alt: 'OKC kitchen with realistic wood-look laminate flooring' },
 { src: '/images/photos/tile/tile1.webp', alt: 'Spa-style bathroom tile install in an Oklahoma City home' },
 { src: '/images/photos/carpet/carpetbasement.webp', alt: 'Cozy carpeted basement family room installed in an OKC home' },
 { src: '/images/photos/hardwood/wideplank.webp', alt: 'Wide-plank engineered wood detail in an Edmond, OK home' },
];
---
<BaseLayout
 title="Flooring Store Oklahoma City | Carpet, Hardwood, LVP & Tile | Floors To You OKC"
 description="Oklahoma City's largest in-stock flooring showroom. Carpet, hardwood, LVP, laminate & tile installed across OKC, Edmond, Yukon, Moore & Norman. 0% financing. Free in-home estimates."
>
 <section class="relative overflow-hidden bg-gradient-to-br from-cream via-brand-50 to-brand-100">
 <div aria-hidden class="pointer-events-none absolute -top-32 -right-32 w-[36rem] h-[36rem] rounded-full bg-brand-300/35 blur-3xl"></div>
 <div aria-hidden class="pointer-events-none absolute -bottom-40 -left-32 w-[30rem] h-[30rem] rounded-full bg-brand-500/15 blur-3xl"></div>

 <div class="container-x relative grid lg:grid-cols-[1.05fr_1fr] gap-10 lg:gap-16 items-center py-14 lg:py-24">
 <div>
 <GoogleReviewsBadge class="mb-6" label="Reviewed by OKC Homeowners" />


 <h1 class="mb-5">
 <span class="block text-brand-800">Oklahoma City Flooring.</span>
 <span class="block text-brand-500">Brought To Your Living Room.</span>
 </h1>

 <p class="text-lg md:text-xl text-ink/80 leading-relaxed mb-7 max-w-xl">
 We bring carpet, hardwood, LVP, laminate and tile to your home - matched to <strong class="text-brand-800">your light and your trim</strong>, then installed across the OKC metro in as little as 24 hours. The kind of floors friends ask about.
 </p>

 <div class="flex flex-wrap gap-3 mb-8">
 <a href="/book" class="btn-primary">Get My Free Estimate</a>
 <a href="/services" class="btn-outline">Shop Flooring</a>
 </div>

 <ul class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-ink/70">
 <li class="flex items-center gap-2"><span class="text-brand-500" aria-hidden>✓</span> Lowest price guaranteed</li>
 <li class="flex items-center gap-2"><span class="text-brand-500" aria-hidden>✓</span> Installed in as little as 24 hours</li>
 <li class="flex items-center gap-2"><span class="text-brand-500" aria-hidden>✓</span> 0% APR for 24 months</li>
 </ul>

 {/* Happy families counter - animated count-up on viewport entry. */}
 <div class="mt-8 inline-flex items-center gap-4 sm:gap-5 rounded-2xl bg-white/85 backdrop-blur ring-1 ring-brand-200 shadow-card px-5 py-4 sm:px-6 sm:py-5">
 <div class="flex -space-x-2.5">
 <span class="grid h-10 w-10 sm:h-11 sm:w-11 place-items-center rounded-full bg-brand-500 text-white font-display font-bold text-xs sm:text-sm ring-2 ring-white" aria-hidden="true">SM</span>
 <span class="grid h-10 w-10 sm:h-11 sm:w-11 place-items-center rounded-full bg-brand-700 text-white font-display font-bold text-xs sm:text-sm ring-2 ring-white" aria-hidden="true">JR</span>
 <span class="grid h-10 w-10 sm:h-11 sm:w-11 place-items-center rounded-full bg-brand-400 text-white font-display font-bold text-xs sm:text-sm ring-2 ring-white" aria-hidden="true">AB</span>
 <span class="grid h-10 w-10 sm:h-11 sm:w-11 place-items-center rounded-full bg-brand-800 text-white font-display font-bold text-[10px] sm:text-xs ring-2 ring-white" aria-hidden="true">+2.5k</span>
 </div>
 <div class="leading-tight">
 <div class="font-display font-bold text-3xl sm:text-4xl text-brand-500">
 <span data-fty-count="2500" data-fty-suffix="+">0+</span>
 </div>
 <div class="text-[10px] sm:text-xs uppercase tracking-[0.18em] font-bold text-brand-800 mt-0.5">Happy Oklahoma Families</div>
 <div class="text-[10px] sm:text-xs text-ink/55 mt-0.5">Served across the OKC metro since 2018</div>
 </div>
 </div>

 {/* Count-up animation on viewport entry. Runs once per element. */}
 <script is:inline>
 (function () {
 const els = document.querySelectorAll('[data-fty-count]');
 if (!els.length) return;
 const io = new IntersectionObserver((entries) => {
 entries.forEach((e) => {
 if (!e.isIntersecting) return;
 const el = e.target;
 const target = parseInt(el.dataset.ftyCount, 10) || 0;
 const suffix = el.dataset.ftySuffix || '';
 const dur = 1600;
 const start = performance.now();
 const tick = (now) => {
 const p = Math.min(1, (now - start) / dur);
 const eased = 1 - Math.pow(1 - p, 3);
 el.textContent = Math.round(target * eased).toLocaleString() + suffix;
 if (p < 1) requestAnimationFrame(tick);
 };
 requestAnimationFrame(tick);
 io.unobserve(el);
 });
 }, { threshold: 0.4 });
 els.forEach((el) => io.observe(el));
 })();
 </script>
 </div>

 <div class="relative">
 <div aria-hidden class="absolute -inset-4 rounded-[2rem] bg-gradient-to-tr from-brand-300/40 to-brand-500/20 blur-2xl"></div>

 <div class="relative grid grid-cols-5 grid-rows-6 gap-3 lg:gap-4 h-[28rem] md:h-[34rem]">
 <img
 src="/images/photos/hardwood/hardwood-full-home.webp"
 alt="Spacious open-concept Oklahoma City home with wide-plank hardwood flooring by Floors To You OKC"
 loading="eager"
 fetchpriority="high"
 width="900"
 height="700"
 class="col-span-3 row-span-6 w-full h-full object-cover rounded-xl2 shadow-soft"
 />
 <img
 src="/images/photos/tile/tileluxuryhome.webp"
 alt="Large-format tile flooring in a luxury Oklahoma City home"
 loading="eager"
 width="600"
 height="400"
 class="col-span-2 row-span-3 w-full h-full object-cover rounded-xl2 shadow-soft"
 />
 <img
 src="/images/photos/lvp/luxuryvinly.webp"
 alt="Waterproof luxury vinyl plank in a modern OKC living room"
 loading="eager"
 width="600"
 height="400"
 class="col-span-2 row-span-3 w-full h-full object-cover rounded-xl2 shadow-soft"
 />
 </div>

 <div class="hidden md:flex absolute -bottom-6 -left-6 lg:-left-10 z-10 items-center gap-3 bg-white rounded-xl2 shadow-soft px-5 py-4 max-w-xs">
 <div class="grid place-items-center w-11 h-11 rounded-full bg-brand-500 text-white font-display text-lg" aria-hidden>2.5k</div>
 <div>
 <p class="font-semibold text-brand-800 leading-tight">2,500+ OKC installs</p>
 <p class="text-xs text-ink/65">Locally owned since 2018</p>
 </div>
 </div>

 <div class="hidden md:flex absolute -top-5 -right-3 lg:-right-6 z-10 items-center gap-2 bg-brand-800 text-white rounded-full pl-2 pr-4 py-2 shadow-soft">
 <span class="grid place-items-center w-8 h-8 rounded-full bg-brand-500 text-white text-sm font-bold" aria-hidden>0%</span>
 <span class="text-sm font-semibold">APR · 24 months</span>
 </div>
 </div>
 </div>
 </section>

 <section class="bg-brand-800 text-white">
 <div class="container-x py-10 grid sm:grid-cols-2 md:grid-cols-4 gap-6 text-center">
 <div><p class="font-display text-3xl text-brand-300">2,500+</p><p class="text-sm text-white/80">Local installs</p></div>
 <a href={googleReviewsUrl} target="_blank" rel="noopener" class="no-underline group"><p class="font-display text-3xl text-brand-300 group-hover:text-brand-200 transition-colors">★★★★★</p><p class="text-sm text-white/80">Google reviewed</p></a>
 <div><p class="font-display text-3xl text-brand-300">24hr</p><p class="text-sm text-white/80">Install turnaround</p></div>
 <div><p class="font-display text-3xl text-brand-300">0% APR</p><p class="text-sm text-white/80">Financing 24 mo.</p></div>
 </div>
 </section>

 {/* ───────── WHY VISIT 6 SHOWROOMS? ───────── */}
 <section class="bg-cream py-16 md:py-24">
 <div class="container-x">
 <div class="text-center max-w-3xl mx-auto mb-12">
 <p class="eyebrow mb-3">Skip The Showroom Hop</p>
 <h2>Why Drive To 6 Different Showrooms When One Will Come To You?</h2>
 <p class="mt-4 text-lg text-ink/75 leading-relaxed">Shopping for floors in OKC usually means burning a Saturday store-hopping, squinting at sample chips under fluorescent lights, and getting pitched by commission salespeople. We replaced all of that.</p>
 </div>

 <div class="grid md:grid-cols-2 gap-6 max-w-5xl mx-auto">
 {/* The old way */}
 <div class="rounded-xl2 bg-white ring-1 ring-brand-100 p-7 sm:p-8">
 <div class="inline-flex items-center gap-2 rounded-full bg-ink/5 px-3 py-1 mb-5">
 <span class="text-xs font-bold uppercase tracking-[0.2em] text-ink/60">The Old Way</span>
 </div>
 <ul class="space-y-3 text-ink/70">
 <li class="flex items-start gap-3"><span class="text-ink/40 mt-0.5 flex-none" aria-hidden>✗</span> Drive across OKC to 6 different stores</li>
 <li class="flex items-start gap-3"><span class="text-ink/40 mt-0.5 flex-none" aria-hidden>✗</span> Squint at sample chips under fluorescent lights</li>
 <li class="flex items-start gap-3"><span class="text-ink/40 mt-0.5 flex-none" aria-hidden>✗</span> Get followed by a commission salesperson</li>
 <li class="flex items-start gap-3"><span class="text-ink/40 mt-0.5 flex-none" aria-hidden>✗</span> Wait 4-6 weeks for a "special order"</li>
 <li class="flex items-start gap-3"><span class="text-ink/40 mt-0.5 flex-none" aria-hidden>✗</span> Juggle a measurer, a delivery driver, and an installer</li>
 <li class="flex items-start gap-3"><span class="text-ink/40 mt-0.5 flex-none" aria-hidden>✗</span> Guess what the floor will look like in your room</li>
 </ul>
 </div>

 {/* The Floors To You way */}
 <div class="rounded-xl2 bg-brand-800 text-white ring-2 ring-brand-500 shadow-soft p-7 sm:p-8 relative overflow-hidden">
 <div aria-hidden class="absolute -top-20 -right-20 w-60 h-60 rounded-full bg-brand-500/25 blur-3xl"></div>
 <div class="relative">
 <div class="inline-flex items-center gap-2 rounded-full bg-brand-500 px-3 py-1 mb-5">
 <span class="text-xs font-bold uppercase tracking-[0.2em] text-white">The Floors To You Way</span>
 </div>
 <ul class="space-y-3 text-white/90">
 <li class="flex items-start gap-3"><span class="text-brand-400 mt-0.5 flex-none" aria-hidden>✓</span> One 60-second form. We come to you.</li>
 <li class="flex items-start gap-3"><span class="text-brand-400 mt-0.5 flex-none" aria-hidden>✓</span> Samples viewed in <strong class="text-white">your actual light</strong></li>
 <li class="flex items-start gap-3"><span class="text-brand-400 mt-0.5 flex-none" aria-hidden>✓</span> Zero pressure - we leave you alone with the quote</li>
 <li class="flex items-start gap-3"><span class="text-brand-400 mt-0.5 flex-none" aria-hidden>✓</span> In-stock material - next-day install</li>
 <li class="flex items-start gap-3"><span class="text-brand-400 mt-0.5 flex-none" aria-hidden>✓</span> One team handles measure, deliver, install &amp; cleanup</li>
 <li class="flex items-start gap-3"><span class="text-brand-400 mt-0.5 flex-none" aria-hidden>✓</span> Walk in a week later and stop in your tracks</li>
 </ul>
 </div>
 </div>
 </div>

 <div class="mt-10 text-center">
 <a href="/book" class="btn-primary">Have The Showroom Come To Me</a>
 <p class="mt-3 text-xs sm:text-sm text-ink/55 uppercase tracking-[0.18em] font-semibold">Free · No Obligation · 60 Seconds</p>
 </div>
 </div>
 </section>

 <ServiceGrid />
 <WhyUs />
 <Gallery items={galleryItems} />
 <AreaGrid />
 <Testimonials />
 <CtaBand />
 <FAQ faqs={generalFaqs} heading="Flooring FAQ Oklahoma City Homeowners Ask Most" />

 <Fragment slot="head">
 <FAQSchema faqs={generalFaqs} />
 </Fragment>
</BaseLayout>
